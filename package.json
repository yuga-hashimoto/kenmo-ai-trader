{
  "name": "kenmo-ai-trader",
  "version": "0.1.0",
  "private": true,
  "description": "kenmo-style mid/small-cap growth investing autopilot — backtest-only MVP with a pluggable HermesAgent and pseudo Broker API.",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "db:generate": "pnpm --filter @kenmo/db generate",
    "db:migrate": "pnpm --filter @kenmo/db migrate",
    "db:push": "pnpm --filter @kenmo/db push",
    "db:seed": "pnpm --filter @kenmo/db seed",
    "dev:api": "pnpm --filter @kenmo/api dev",
    "dev:web": "pnpm --filter @kenmo/web dev",
    "data:bootstrap:free": "tsx scripts/trigger_bootstrap.js",
    "data:quality": "tsx scripts/run_quality.js",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm --filter @kenmo/core test && pnpm --filter @kenmo/hermes test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
