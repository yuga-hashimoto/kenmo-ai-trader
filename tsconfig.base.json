{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@kenmo/core": ["packages/core/src/index.ts"],
      "@kenmo/core/*": ["packages/core/src/*"],
      "@kenmo/db": ["packages/db/src/index.ts"],
      "@kenmo/hermes": ["packages/hermes/src/index.ts"]
    }
  }
}
