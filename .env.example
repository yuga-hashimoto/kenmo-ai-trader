# ---- Database (Prisma / API) ----
DATABASE_URL="postgresql://kenmo:kenmo@localhost:5432/kenmo?schema=public"

# ---- API ----
API_PORT=4000

# ---- Web -> API ----
# Next.js rewrites /api/* to this URL (server-side).
API_INTERNAL_URL="http://localhost:4000"

# ---- HermesAgent backend ----
# "mock"   = deterministic rule-based agent (default, no credentials needed)
# "remote" = OpenHermesAgentClient -> your HermesAgent service (falls back to mock if unset)
HERMES_MODE="mock"
HERMES_AGENT_ENDPOINT=""
HERMES_AGENT_API_KEY=""
HERMES_AGENT_MODEL=""

# ---- Realtime scheduler (Paper/Live session loop) ----
# When true, the API runs RealtimeMarketScheduler and fires JST session events
# (prepare_watchlist / monitor_and_trade / ... / after_close_analysis) on trading days.
ENABLE_REALTIME_SCHEDULER="false"
SCHEDULER_POLL_MS="60000"

# ---- Market data provider routing ----
# "seed" (default) | "jquants" | "csv" | "router" (auto-selects by mode)
MARKET_DATA_PROVIDER="seed"
JQUANTS_BASE_URL="https://api.jquants.com/v1"

# ---- Live trading safety gate (TRIPLE GATE) ----
# MUST stay false. LiveBrokerAdapter ships with a disabled stub client; real orders are
# never sent. Enabling requires ALL of: ENABLE_LIVE_TRADING=true + in-app confirmation +
# per-order confirmation token + a real broker client wired in code (not shipped).
ENABLE_LIVE_TRADING="false"

# ---- J-Quants API (market data only — not a brokerage credential) ----
# Obtain at https://jpx-jquants.com/
# Plan options: free | standard | premium
JQUANTS_EMAIL=
JQUANTS_PASSWORD=
JQUANTS_REFRESH_TOKEN=
JQUANTS_ID_TOKEN=
JQUANTS_PLAN=free
JQUANTS_ENABLE_ADDONS=false

# ---- TDnet (適時開示) — disabled by default, API is commercial ----
TDNET_API_BASE_URL=
TDNET_API_KEY=
TDNET_ENABLED=false

# ---- EDINET (有価証券報告書) — disabled by default ----
# Register at https://disclosure2.edinet-fsa.go.jp/
EDINET_API_KEY=
EDINET_ENABLED=false

# ---- kabuStation Broker Quote (板/価格照会のみ — 発注API不使用) ----
# MVP: price & board inquiry only. No order placement (LiveBrokerAdapter remains disabled).
KABU_STATION_API_BASE_URL=http://localhost:18080/kabusapi
KABU_STATION_PASSWORD=
KABU_STATION_ENABLED=false
