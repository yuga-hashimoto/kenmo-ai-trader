# ---- Database (Prisma / API) ----
DATABASE_URL="postgresql://kenmo:kenmo@localhost:5432/kenmo?schema=public"

# ---- API ----
API_PORT=4000

# ---- Web -> API ----
# Next.js rewrites /api/* to this URL (server-side).
API_INTERNAL_URL="http://localhost:4000"

# ---- HermesAgent backend ----
# "mock"      = deterministic rule-based agent (default, no credentials needed)
# "remote"    = OpenHermesAgentClient -> your bespoke HermesAgent service
# "local_cli" = LocalCliHermesAgentClient -> spawn the local hermes CLI per call
# "api"       = OpenAICompatHermesAgentClient -> any OpenAI-compatible /chat/completions
#               endpoint (OpenCode Go / OpenRouter / OpenAI / proxy). Recommended for
#               always-on live trading: robust, timed out, falls back to mock on failure.
HERMES_MODE="mock"
HERMES_AGENT_ENDPOINT=""
HERMES_AGENT_API_KEY=""
HERMES_AGENT_MODEL=""

# Used when HERMES_MODE="api". Point at any OpenAI-compatible chat endpoint.
AI_API_BASE_URL="https://opencode.ai/zen/go/v1"
AI_API_MODEL="deepseek-v4-flash"
AI_API_TIMEOUT_MS="120000"
AI_API_KEY=""

# ---- Realtime scheduler (Paper/Live session loop) ----
# When true, the API runs RealtimeMarketScheduler and fires JST session events
# (prepare_watchlist / monitor_and_trade / ... / after_close_analysis) on trading days.
ENABLE_REALTIME_SCHEDULER="false"
SCHEDULER_POLL_MS="60000"
# A fresh live paper run seeds this many recent trading days, then walks forward
# as new data arrives — it does NOT replay all history.
LIVE_BACKFILL_DAYS="5"
# At end-of-day the scheduler ingests fresh daily prices before trading, so the
# full loop (ingest -> screen -> AI -> trade) runs unattended. Set "false" to skip.
ENABLE_AUTO_INGESTION="true"
# "yahoo_finance" (default) | "yfinance_python" — source for the daily ingest.
MARKET_INGEST_SOURCE="yahoo_finance"

# ---- Market data provider routing ----
# "seed" (default) | "jquants" | "csv" | "router" (auto-selects by mode)
MARKET_DATA_PROVIDER="seed"
# Leave empty to auto-select: v2 when JQUANTS_API_KEY is set, otherwise v1 (free plan).
# Only override if you need to pin a specific J-Quants API version.
JQUANTS_BASE_URL=

# ---- Live trading safety gate (TRIPLE GATE) ----
# MUST stay false. LiveBrokerAdapter ships with a disabled stub client; real orders are
# never sent. Enabling requires ALL of: ENABLE_LIVE_TRADING=true + in-app confirmation +
# per-order confirmation token + a real broker client wired in code (not shipped).
ENABLE_LIVE_TRADING="false"

# ---- J-Quants API (market data only — not a brokerage credential) ----
# Obtain at https://jpx-jquants.com/
# Plan options: free | standard | premium
JQUANTS_EMAIL=
JQUANTS_PASSWORD=
JQUANTS_API_KEY=
JQUANTS_REFRESH_TOKEN=
JQUANTS_ID_TOKEN=
JQUANTS_PLAN=free
JQUANTS_ENABLE_ADDONS=false

# ---- Yahoo Finance (yfinance-style public chart data; delayed/informational) ----
YAHOO_FINANCE_ENABLED=true
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com
# Optional comma-separated JP stock codes. When empty, the API uses active DB symbols.
YAHOO_FINANCE_SYMBOLS=
# 0 or empty means all active DB symbols. Set a positive number to cap each run.
YAHOO_FINANCE_MAX_SYMBOLS=0
YAHOO_FINANCE_RATE_LIMIT_MS=0
YAHOO_FINANCE_MAX_CONCURRENT=10

# ---- TDnet (適時開示) — disabled by default, API is commercial ----
TDNET_API_BASE_URL=
TDNET_API_KEY=
TDNET_ENABLED=false

# ---- EDINET (有価証券報告書) — disabled by default ----
# Register at https://disclosure2.edinet-fsa.go.jp/
EDINET_API_KEY=
EDINET_ENABLED=false

# ---- kabuStation Broker Quote (板/価格照会のみ — 発注API不使用) ----
# MVP: price & board inquiry only. No order placement (LiveBrokerAdapter remains disabled).
KABU_STATION_API_BASE_URL=http://localhost:18080/kabusapi
KABU_STATION_PASSWORD=
KABU_STATION_ENABLED=false
